{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BiblePro",
  "version": "0.1.0",
  "identifier": "com.dev.biblepro",
  "build": {
    "beforeDevCommand": {
      "script": "npm install && npm run dev",
      "cwd": "../ui"
    },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": {
      "script": "npm run build",
      "cwd": "../ui"
    },
    "frontendDist": "../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "BiblePro",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "resources/fonts/*": "resources/fonts"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
